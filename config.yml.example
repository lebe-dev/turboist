# IANA timezone for day part calculations (e.g. "Europe/Moscow", "America/New_York").
# Overrides browser-detected timezone on the frontend.
# Default: UTC
timezone: "Europe/Moscow"

# Todoist API polling interval. Format: Go duration (5s, 30s, 1m, ...)
# Default: 30s
poll_interval: "30s"

# Contexts — named filter sets for tasks.
# Each context has a unique id used in query params (?context=health).
# All conditions within a single context are combined with AND.
# Multiple values within an array are combined with OR.
contexts:
  - id: health
    display_name: "Здоровье"
    inherit_labels: true
    color: green
    filters:
      # Filter by Todoist labels (OR between items)
      labels: ["здоровье"]

  - id: dev
    display_name: "Разработка"
    color: "#FF5733"
    inherit_labels: false
    filters:
      # Filter by Todoist project names (OR between items)
      projects: ["Проекты"]
      # Filter by section names within a project (OR between items)
      sections: ["Секция - Разработка"]
      # Filter by Todoist labels (OR between items)
      labels: ["проект"]

  - id: work
    display_name: "Работа"
    color: "#3B82F6"
    inherit_labels: true
    filters:
      labels: ["работа"]

# Label behavior overrides.
# Only labels that need non-default behavior should be listed here.
# inherit_to_subtasks: whether this label is inherited when creating subtasks (default: true)
labels:
  - name: "проект"
    inherit_to_subtasks: false
  - name: "на неделе"
    inherit_to_subtasks: false
  - name: "backlog"
    inherit_to_subtasks: false

# Tasks for the current week
weekly:
  # Todoist label that marks tasks for the current week
  label: "на неделе"
  # Maximum number of tasks per week (used for the progress bar and warnings)
  max_tasks: 15

# Tasks for the next week
backlog:
  # Todoist label for next week's tasks
  label: "на след неделе"

  #task_sort: ""

# Task sorting. Options: priority, due_date, content
# Default: priority (highest first, then by due date)
task_sort: "priority"

# Tasks for today (filtered by due date)
today:
  # Include overdue tasks (due date before today) in the "Today" view
  include_overdue: true
  # Day parts: split today's tasks into time-based sections.
  # Tasks are assigned to sections via Todoist labels.
  # Omit or leave empty to disable sectioning.
  day_parts:
    - label: "утро"
      start: 8
      end: 12
    - label: "день"
      start: 12
      end: 16
    - label: "вечер"
      start: 16
      end: 23

# Tasks for tomorrow (filtered by due date)
tomorrow: {}

# Auto-expire: tasks with the given label are closed (completed) after the TTL elapses.
# TTL is counted from the moment the label is first seen in the cache (first_seen).
# The timer resets on application restart.
# Tasks are closed (not deleted): they remain in the completed history and can be restored.
auto_expire:
  - label: "срочное"
    ttl: "24h"
  - label: "горит"
    ttl: "4h"

# Quick capture — save ideas as subtasks under a parent task
quick_capture:
  title: "Проект - turboist"
