# IANA timezone for day part calculations (e.g. "Europe/Moscow", "America/New_York").
# Overrides browser-detected timezone on the frontend.
# Default: UTC
timezone: "Europe/Moscow"

# Todoist API polling interval. Format: Go duration (5s, 30s, 1m, ...)
# Default: 30s
poll_interval: "30s"

# Contexts — named filter sets for tasks.
# Each context has a unique id used in query params (?context=health).
# All conditions within a single context are combined with AND.
# Multiple values within an array are combined with OR.
contexts:
  - id: health
    display_name: "Здоровье"
    inherit_labels: true
    color: green
    filters:
      # Filter by Todoist labels (OR between items)
      labels: ["здоровье"]

  - id: dev
    display_name: "Разработка"
    color: "#FF5733"
    inherit_labels: false
    filters:
      # Filter by Todoist project names (OR between items)
      projects: ["Проекты"]
      # Filter by section names within a project (OR between items)
      sections: ["Секция - Разработка"]
      # Filter by Todoist labels (OR between items)
      labels: ["проект"]

  - id: work
    display_name: "Работа"
    color: "#3B82F6"
    inherit_labels: true
    filters:
      labels: ["работа"]

# Label behavior overrides.
# Only labels that need non-default behavior should be listed here.
# inherit_to_subtasks: whether this label is inherited when creating subtasks (default: true)
labels:
  - name: "проект"
    inherit_to_subtasks: false
  - name: "на неделе"
    inherit_to_subtasks: false
  - name: "backlog"
    inherit_to_subtasks: false

# Project tasks — tasks tagged with this label are treated as projects.
project:
  label: "проект"

# Tasks for the current week
weekly:
  # Todoist label that marks tasks for the current week
  label: "на неделе"
  # Maximum number of tasks per week (used for the progress bar and warnings)
  max_tasks: 15

# Backlog tasks
backlog:
  # Todoist label for backlog tasks
  label: "backlog"
  # Sort order within backlog. Options: priority, due_date, content, added_at (default: added_at)
  task_sort: "added_at"
  # Maximum tasks shown in the backlog view (default: 20)
  max_limit: 20

# Task sorting. Options: priority, due_date, content, added_at
# Default: priority (highest first, then by due date)
task_sort: "priority"

# Maximum number of pinned tasks in the sidebar (default: 5)
max_pinned: 5

# Tasks for today (filtered by due date)
today:
  # Include overdue tasks (due date before today) in the "Today" view
  include_overdue: true
  # Day parts: split today's tasks into time-based sections.
  # Tasks are assigned to sections via Todoist labels.
  # Omit or leave empty to disable sectioning.
  day_parts:
    - label: "утро"
      start: 8
      end: 12
    - label: "день"
      start: 12
      end: 16
    - label: "вечер"
      start: 16
      end: 23

# Tasks for tomorrow (filtered by due date)
tomorrow: {}

# Completed tasks view
completed:
  # How many days back to show completed tasks (default: 3)
  days: 3

# Quick capture — save ideas as subtasks under a parent task
quick_capture:
  title: "Inbox"

# Auto-tags: automatically add labels when the task title contains the mask substring.
# Tags appear in real time while typing and are visually distinct from manually chosen labels.
# The user can remove an auto-tag before submitting; it will not reappear for that entry.
# mask        — substring to look for in the task title.
# label       — Todoist label name to attach when the mask is found.
# ignore_case — case-insensitive matching (default: true).
auto_tags:
  - mask: "купить"
    label: "покупки"
  - mask: "встреча"
    label: "работа"
  - mask: "созвон"
    label: "работа"
  - mask: "Проект -"
    label: "проект"
    ignore_case: false

# Auto-expire: tasks with the given label are completed after the TTL elapses.
# TTL is counted from the moment the label is first seen in the cache.
# The timer resets on application restart.
# Tasks are completed (not deleted): they remain in the completed history.
auto_expire:
  - label: "срочное"
    ttl: "24h"
  - label: "горит"
    ttl: "4h"
