# Address and port the HTTP server listens on
# Default: :8080
BIND=:8080

# Log level: debug | info | warn | error
# Default: info
LOG_LEVEL=info

# Base URL of the application (used when constructing links)
# Default: http://localhost:8080
BASE_URL=http://localhost:8080

# Todoist API key. Get it at: https://app.todoist.com/app/settings/integrations/developer
# Required
TODOIST_API_KEY=

# Password for logging into Turboist (single-user, stored plain-text — intentional trade-off:
# if an attacker can read ENV, they already have access to TODOIST_API_KEY as well)
# Required
TURBOIST_ADMIN_PASSWORD=

# Enable dev mode: proxy frontend requests to Vite (localhost:5173), disable Secure cookie flag
# Default: false
DEV=false
