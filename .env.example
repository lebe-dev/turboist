# Address and port the HTTP server listens on. Required.
BIND=0.0.0.0:8080

# Log level: debug | info | warn | error (case-insensitive). Default: info.
LOG_LEVEL=info

# Base URL of the application (used when constructing Task.URL). Required.
BASE_URL=http://localhost:8080

# Secret for signing JWT access tokens. Minimum 32 bytes in base64. Required.
JWT_SECRET=

# Path to the SQLite database file. Default: data/turboist.db
# DATA_PATH=data/turboist.db

# --- argon2id password hashing -------------------------------------------------
# Defaults follow the OWASP minimum profile (m=19 MiB, t=2, p=1) and fit
# comfortably in a small container (e.g. 64 MiB RAM). Increase for stronger
# resistance against offline cracking if your host has more memory.
#
# Hash cost is encoded in each PHC string, so changing these values affects
# only newly created hashes; existing users stay verifiable with their old
# parameters.

# Memory cost in KiB. Each concurrent hash allocates this much RAM.
# Default: 19456 (19 MiB). OWASP min: 19 MiB. Recommended for ample RAM: 65536 (64 MiB).
# ARGON2_MEMORY_KIB=19456

# Number of iterations (time cost). Default: 2. Higher = slower but more secure.
# ARGON2_TIME=2

# Parallelism (number of lanes). Default: 1. Bump only if you have spare CPU
# cores for hashing and multiply ARGON2_MEMORY_KIB by lanes mentally when sizing the host.
# ARGON2_THREADS=1
