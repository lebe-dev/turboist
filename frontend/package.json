		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@eslint/js": "^9.18.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.6",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^9.18.0",
		"eslint-plugin-svelte": "^3.0.0",
